# Copy to .env.local and fill in values from: supabase status
#
#   cp .env.example .env.local
#
# Use the local API URL and anon (publishable) key only.
# Never put service_role or database passwords in the Next.js app.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status

# Hosted app values use the same public names.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-cloud-anon-key

# Optional: local-only RLS smoke tests.
# Do not expose this in browser code or hosted frontend environments.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status
