# Copy to .env.local and fill in values from: supabase status
#
#   cp .env.example .env.local
#
# Use the local API URL and anon (publishable) key only.
# Never put service_role or database passwords in the Next.js app.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status
